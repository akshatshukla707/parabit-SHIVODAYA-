{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build C program with pthread",
      "type": "shell",
      "command": "gcc",
      "args": [
        "${file}",            // the currently open file
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe",
        "-lpthreadGC2"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "detail": "Compile the active C file with pthread support"
    }
  ]
}
